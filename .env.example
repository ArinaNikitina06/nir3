# Скопируйте в .env.local и подставьте свои значения:
#   cp .env.example .env.local

# PostgreSQL (если базы нет — часть API всё равно отдаёт демо-данные)
# Порт 5433 — если 5432 уже занят другим Docker-проектом (см. docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/nir3"

NEXTAUTH_URL="http://127.0.0.1:3000"
# Сгенерируйте случайную строку, минимум ~32 символа
NEXTAUTH_SECRET="замените-на-случайную-длинную-строку-для-разработки"
